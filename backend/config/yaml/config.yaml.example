# RAGSystem 用户配置文件
# 将此文件复制为 config.yaml，并填写您的配置信息

# Neo4j 配置
neo4j:
  # uri: bolt://localhost:7687  # 数据库连接地址
  # user: neo4j                  # 数据库用户名
  password: "your_neo4j_password"  # 数据库密码

# LLM 配置
llm:
  # api_endpoint: https://api.deepseek.com/v1  # API 端点
  api_key: "your_deepseek_api_key"              # DeepSeek API 密钥
  # model_name: deepseek-chat                   # 模型名称
  # temperature: 0.7                             # 生成温度
  # max_tokens: 4096                             # 最大令牌数

# 系统配置
system:
  # max_content_length: 104857600  # 文件上传限制 (字节)

# 外部库配置（llmjson 和 json2graph-for-review）
external_libs:
  # llmjson:
  #   enabled: true
  #   settings: {}

  # json2graph:
  #   enabled: true
  #   settings: {}
