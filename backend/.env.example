# 默认 LLM 配置（可选；更推荐在 providers.yaml 中配置）
LLM_API_ENDPOINT=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL_NAME=gpt-4o-mini

# 地理编码服务配置（可选）
GEOCODING_SERVICE=baidu
GEOCODING_API_KEY=your-geocoding-api-key

# Flask / 开发服务器配置
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true
FLASK_USE_RELOADER=true

# 跨域白名单（逗号分隔）
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5174,http://127.0.0.1:5174

# 静态文件与上传目录（相对路径按 backend 目录解析）
UPLOAD_FOLDER=uploads
FRONTEND_DIST=../frontend-client/dist

# 系统配置
MAX_WORKERS=4
DATA_DIRECTORY=./data
DATA_VALIDATION=true
PYTHON_PATH=python3
