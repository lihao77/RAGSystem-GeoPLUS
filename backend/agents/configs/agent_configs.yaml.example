# 智能体配置示例文件
#
# 这是一个配置模板，实际使用的配置文件会在首次运行时自动生成
# 文件位置：backend/agents/configs/agent_configs.yaml
#
# 配置说明：
# - agent_name: 智能体唯一标识（必填）
# - display_name: 显示名称（可选）
# - description: 智能体描述（可选）
# - enabled: 是否启用（默认 true）
# - llm: LLM 配置（可选，不配置则使用系统默认）
#   - provider: LLM Provider 名称（如 deepseek, openai）
#   - model_name: 模型名称（如 deepseek-chat, gpt-4）
#   - temperature: 生成温度 (0-2)
#   - max_tokens: 最大生成 token 数
#   - top_p: Top-p 采样参数 (0-1)
#   - timeout: 超时时间（秒）
#   - retry_attempts: 重试次数
# - tools: 工具配置（可选）
#   - enabled_tools: 启用的工具列表（留空表示全部启用）
# - custom_params: 自定义参数（可选）

agents:
  # 问答智能体配置示例
  qa_agent:
    agent_name: qa_agent
    display_name: 问答智能体
    description: 知识图谱问答智能体，使用 Function Calling 进行查询
    enabled: true
    llm:
      provider: null          # null 表示使用系统默认
      model_name: null
      temperature: 0.2        # 低温度，更确定性
      max_tokens: 4096
      top_p: null
      timeout: 30
      retry_attempts: 3
    tools:
      enabled_tools:
        - query_kg
        - semantic_search
        - cypher_query
    custom_params:
      max_rounds: 5

  # 主协调智能体配置示例
  master_agent:
    agent_name: master_agent
    display_name: 主协调智能体
    description: 主协调智能体，负责任务分析、分解和结果整合
    enabled: true
    llm:
      provider: null
      model_name: null
      temperature: 0.0        # 任务分析需要确定性
      max_tokens: 2000
      top_p: null
      timeout: 30
      retry_attempts: 3
    tools:
      enabled_tools: []       # 空列表表示启用所有工具
    custom_params:
      analysis_temperature: 0.0
      synthesis_temperature: 0.3

# 元数据（自动生成）
metadata:
  version: '1.0'
  updated_at: '2026-01-04T00:00:00'
