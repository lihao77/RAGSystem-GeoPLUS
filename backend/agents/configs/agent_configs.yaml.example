# 智能体配置示例（与 AgentConfig 模型一致）
# 可选：不存在时由 AgentConfigManager 创建默认。复制为 agent_configs.yaml 后按需修改。
# llm.provider + llm.provider_type 对应 providers.yaml 中的复合键（如 my_deepseek）

agents:
  qa_agent:
    agent_name: qa_agent
    display_name: "问答助手"
    description: "示例智能体"
    enabled: true
    llm:
      provider: my
      provider_type: deepseek
      model_name: deepseek-chat
      temperature: 0.3
      max_completion_tokens: 4096      # 单次输出的最大 token 数
      max_context_tokens: 128000       # 模型支持的最大上下文窗口（128K）
      timeout: 30
      retry_attempts: 3

    # 可选：多层级 LLM 配置（类似 Claude Code 的 sonnet/haiku/opus 设计）
    # 不配置时所有任务都使用上面的默认 llm 配置
    llm_tiers:
      # fast: 快速模型，用于简单任务（压缩、格式化、简单判断）
      fast:
        provider: my
        provider_type: deepseek
        model_name: deepseek-chat      # 或使用更便宜的模型如 glm-4-flash
        temperature: 0.2
        max_completion_tokens: 1000

      # default: 默认模型（不配置时使用主 llm 配置）
      # default:
      #   provider: null  # 留空表示使用主 llm 配置

      # powerful: 强力模型，用于复杂推理和困难任务
      # powerful:
      #   provider: my
      #   provider_type: openrouter
      #   model_name: anthropic/claude-3.5-sonnet
      #   temperature: 0.5
      #   max_completion_tokens: 8192

    tools:
      enabled_tools:
        - read_document
        - chunk_document
        - extract_structured_data
        - generate_chart
        - execute_code
    skills:
      enabled_skills: []
      auto_inject: true
    # MCP Server 配置（可选）
    # 需要先在 backend/mcp/configs/mcp_servers.yaml 中添加对应 Server
    # mcp:
    #   enabled_servers:
    #     - filesystem      # 使用文件系统 MCP Server 的工具
    #     - brave_search    # 使用 Brave 搜索 MCP Server 的工具
    custom_params:
      type: react
      behavior:
        system_prompt: "你是问答助手"
        max_rounds: 10
        auto_execute_tools: true
        # max_context_tokens: 80000           # 可选：显式指定对话历史的上下文预算（覆盖自动计算）
        # compression_trigger_ratio: 0.85     # 可选：触发压缩的 token 比例（默认 0.85）
        # summarize_max_tokens: 300           # 可选：LLM 摘要的最大 token 数（默认 300）
        # preserve_recent_turns: 3            # 可选：保留最近 N 轮对话不压缩（默认 3）

  # 系统级智能体，始终加载（与其他 Agent 不同，enabled 字段无效）
  master_agent_v2:
    agent_name: master_agent_v2
    display_name: Master Agent V2 (动态编排)
    description: 动态智能体编排器，将 Agent 当作工具使用，通过 ReAct 模式实时决策
    enabled: true
    llm:
      provider: my
      provider_type: deepseek
      model_name: deepseek-chat
      temperature: 0.3
      max_completion_tokens: 4096
      max_context_tokens: 128000
      timeout: 60
      retry_attempts: 3
    # llm_tiers:                              # 可选：多层级 LLM 配置
    #   fast:
    #     provider: my
    #     provider_type: deepseek
    #     model_name: deepseek-chat
    #     max_completion_tokens: 1000
    tools:
      enabled_tools: []                       # 留空；工具由运行时动态注入（invoke_agent_xxx 等）
    skills:
      enabled_skills: []
      auto_inject: false
    custom_params:
      type: master_v2
      behavior:
        system_prompt: "你是一个智能体编排器，可以动态调用其他 Agent 完成复杂任务。"
        max_rounds: 15
        compression_trigger_ratio: 0.85
        summarize_max_tokens: 300
        preserve_recent_turns: 3
        data_save_dir: ./static/temp_data
        # max_context_tokens: 100000          # 可选：显式指定上下文预算（覆盖自动计算）
